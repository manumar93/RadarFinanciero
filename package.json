{
  "name": "radarfinanciero",
  "version": "1.0.0",
  "private": true,
  "description": "RadarFinanciero con backend Node preparado para Express y Supabase.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "check": "node --check server.js && node --check src/app.js && node --check src/routes/api.routes.js && npm run lint",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}
